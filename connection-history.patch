+                data = json.load(history_file)
+        except (OSError, json.JSONDecodeError):
+            return []
+
+        if isinstance(data, dict):
+            history = data.get("history", {}).get("value", [])
+            return history if isinstance(history, list) else []
+        if isinstance(data, list):
+            return data
+        return []
